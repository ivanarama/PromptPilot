# PromptPilot configuration
# Rename to .env and place next to pp.exe (or in ~/.promptpilot/)
# Values here are only used if the variable is NOT already set in the environment

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Token from @BotFather
PP_TG_TOKEN=your-bot-token-here

# Comma-separated list of allowed phone numbers (international format)
PP_TG_ALLOWED_PHONES=+79001234567,+79007654321

# ── Claude CLI ───────────────────────────────────────────────────────────────
# Full path to claude.exe (default: ~/.local/bin/claude.exe)
PP_CLAUDE_EXE=C:\Users\YourName\.local\bin\claude.exe

# ── PromptPilot ──────────────────────────────────────────────────────────────
# Default provider: claude, claude-z, codex, qwen, or any custom name
PP_DEFAULT_CLI=claude

# Where to store the database and config files (default: ~/.promptpilot)
# PP_DATA_DIR=C:\PromptPilot\data

# Root folder for project selection in bot/UI (subdirs shown as buttons)
# PP_PROJECTS_ROOT=C:\Projects

# Optional password required to create tasks via Telegram bot (leave empty to disable)
# PP_TASK_PASSWORD=mysecretpassword

# ── Web server ───────────────────────────────────────────────────────────────
PP_HOST=127.0.0.1
PP_PORT=8420
